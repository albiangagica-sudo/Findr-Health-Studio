# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# The secret passcode for the private preview gate.
VITE_APP_PASSCODE="2026"

# Findr backend API base URL — defaults to current Railway production URL if unset.
# Updated during Findr Phase 3 migration when backend moves to API Gateway.
VITE_FINDR_API_BASE_URL=https://fearless-achievement-production.up.railway.app
